# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/flowboard?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# OAuth — at least one provider required
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server (optional)
PORT=3000

# GraphQL rate limit — requests per minute per user/IP (optional)
GRAPHQL_RATE_LIMIT=120

# GraphQL max query depth (optional, default 10)
GRAPHQL_MAX_DEPTH=10

# JWT session lifetime in seconds (optional, default 604800 = 7 days)
SESSION_MAX_AGE_SECONDS=604800
